# File-path allowlist for offline-invariant exemptions.
# One file path per line, relative to repo root.
# Each entry MUST include a comment with the spec number that authorized it.

# Spec 15: speech_to_text is allowed only inside the STT service wrapper.
# The plugin's onDevice flag is enforced inside the wrapper; consumers
# elsewhere import lib/services/speech/stt_service.dart instead.
lib/services/speech/stt_service.dart
lib/services/speech/stt_capability_probe.dart

# Spec 16: flutter_tts is allowed only inside the TTS service wrapper.
# The plugin's native engines (AVSpeechSynthesizer / Android TextToSpeech)
# run fully offline; consumers elsewhere import lib/services/speech/tts_service.dart.
lib/services/speech/tts_service.dart

# Spec 17: device_info_plus is allowed only inside the device-capability probe.
# The plugin reads system properties (UIDevice / android.os.Build) and makes
# no network calls; consumers elsewhere import the DeviceCapabilityService
# wrapper at lib/services/device/device_capability_service.dart.
lib/services/device/device_capability_probe.dart

# Spec 19: model download is the one authorized network surface.
# The user opts in explicitly via the AI assist disclosure; the file is
# fetched once, SHA-256 verified, and lives in app-support storage.
# Never extend this allowlist without a written rationale.
lib/services/ai/llm_model_downloader.dart

# Spec 20: llama_cpp_dart is the on-device LLM binding (decision #32).
# The package is FFI to a vendored llama.cpp shared library — no network
# transitively. Wrapping it here keeps Spec 20 success criterion #5 enforceable
# (only this file imports the chosen LLM package directly).
lib/services/ai/llama_cpp_llm_runtime.dart
